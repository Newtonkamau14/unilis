# SmartLab Environment Configuration

# Application
APP_NAME=SmartLab
APP_URL=https://unilis.jhubafrica.com/smart-lab
APP_ENV=production
APP_DEBUG=false

# Database Configuration
DB_HOST=smartlab-db
DB_PORT=3306
DB_NAME=unilis_smartlab
DB_USER=lab_admin
DB_PASSWORD=lab_password
DB_ROOT_PASSWORD=SmartLabRoot2024!

# Redis Configuration (optional)
REDIS_HOST=smartlab-redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Email Configuration
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@unilis.jhubafrica.com
MAIL_FROM_NAME=SmartLab

# Security
JWT_SECRET=your-super-secret-jwt-key-here
QR_SECRET_KEY=your-qr-secret-key-here
SESSION_LIFETIME=7200

# File Uploads
UPLOAD_MAX_SIZE=64M
UPLOAD_ALLOWED_TYPES=jpg,jpeg,png,pdf,doc,docx,xls,xlsx

# Logging
LOG_LEVEL=info
LOG_CHANNEL=daily

# Lab Configuration
DEFAULT_LAB_RADIUS=50
MAX_STUDENTS_PER_SESSION=30
SESSION_TIMEOUT=300

# External Services
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
FIREBASE_PROJECT_ID=your-firebase-project-id

# Monitoring
HEALTH_CHECK_ENABLED=true
METRICS_ENABLED=true

# Backup
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
